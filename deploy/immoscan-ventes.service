[Unit]
Description=ImmoScan - Pipeline ventes (scraping + scoring + alertes Telegram)
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/immoscan
Environment=PATH=/opt/immoscan/venv/bin:/usr/bin:/bin
ExecStart=/opt/immoscan/venv/bin/python scripts/run_pipeline_live.py
StandardOutput=journal
StandardError=journal
TimeoutStartSec=300

